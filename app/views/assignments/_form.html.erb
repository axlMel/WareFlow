<%= form_with(model: assignment, class: "space-y-6") do |form| %>

  <% if assignment.errors.any? %>
    <div class="bg-red-100 text-red-800 border border-red-300 p-4 rounded-xl">
      <ul class="list-disc list-inside text-sm">
        <% assignment.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <!-- USUARIO -->
  <div>
    <%= form.label :user_id, "Usuario", class: "block font-semibold mb-1" %>
    <%= form.collection_select :user_id, @users, :id, :username,
      { prompt: "Selecciona un usuario" },
      class: "w-full border rounded-xl px-3 py-2" %>
  </div>

  <!-- TIPO -->
  <div data-controller="assignment-form">
    <label class="block font-semibold mb-1">Tipo</label>
    <select data-action="change->assignment-form#changeType"
            data-assignment-form-target="type"
            class="w-full border rounded-xl px-3 py-2">
      <option value="">Selecciona tipo</option>
      <option value="product">Producto</option>
      <option value="device">Dispositivo</option>
      <option value="sim">SIM</option>
    </select>

    <!-- PRODUCT -->
    <div data-assignment-form-target="productSection" class="hidden mt-4">
      <%= form.label :product_id, "Producto", class: "block font-semibold mb-1" %>
      <%= form.collection_select :product_id, @products, :id, :title,
        { prompt: "Selecciona producto" },
        class: "w-full border rounded-xl px-3 py-2" %>
    </div>

    <!-- DEVICE -->
    <div data-assignment-form-target="deviceSection" class="hidden mt-4">
      <%= form.label :device_id, "Dispositivo", class: "block font-semibold mb-1" %>
      <%= form.collection_select :device_id, @devices, :id,
        ->(d) { "#{d.imei} - #{d.brand}" },
        { prompt: "Selecciona dispositivo" },
        class: "w-full border rounded-xl px-3 py-2" %>
    </div>

    <!-- SIM -->
    <div data-assignment-form-target="simSection" class="hidden mt-4">
      <%= form.label :sim_id, "SIM", class: "block font-semibold mb-1" %>
      <%= form.collection_select :sim_id, @sims, :id,
        ->(s) { "#{s.iccid} - #{s.provider} - #{s.phone_number}" },
        { prompt: "Selecciona SIM" },
        class: "w-full border rounded-xl px-3 py-2" %>
    </div>

    <!-- QUANTITY -->
    <div data-assignment-form-target="quantitySection" class="hidden mt-4">
      <%= form.label :quantity, "Cantidad", class: "block font-semibold mb-1" %>
      <%= form.number_field :quantity, min: 1,
        class: "w-full border rounded-xl px-3 py-2" %>
    </div>
  </div>

  <div class="text-right pt-4">
    <%= form.submit "Guardar asignación",
      class: "bg-blue-600 hover:bg-blue-700 text-white px-5 py-2 rounded-xl" %>
  </div>

<% end %>