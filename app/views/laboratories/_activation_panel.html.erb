<div class="bg-white rounded-2xl shadow p-6">

  <h2 class="text-lg font-semibold mb-4">Activación</h2>

  <%= form_with url: activate_laboratories_path, method: :post, id: "activation-form" do %>

    <%= hidden_field_tag :device_id, nil, id: "selected_device" %>
    <%= hidden_field_tag :sim_id, nil, id: "selected_sim" %>

    <div class="flex items-center gap-4">
      <span id="selected_device_label" class="text-sm text-gray-500">
        Device: ninguno
      </span>

      <span id="selected_sim_label" class="text-sm text-gray-500">
        SIM: ninguna
      </span>

      <%= submit_tag "Activar",
          class: "px-4 py-2 bg-blue-600 text-white rounded" %>
    </div>

  <% end %>

</div>