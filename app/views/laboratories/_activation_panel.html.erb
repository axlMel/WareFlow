<div class="bg-white rounded-2xl shadow p-6">

  <h2 class="text-lg font-semibold mb-4">Activación</h2>

  <%= form_with url: activate_laboratory_index_path do |f| %>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">

      <div>
        <label class="text-sm text-gray-600">Device</label>
        <%= f.hidden_field :device_id, id: "selected_device" %>
        <div class="border rounded-lg p-2 text-sm text-gray-500">
          Device seleccionado
        </div>
      </div>

      <div>
        <label class="text-sm text-gray-600">SIM</label>
        <%= f.hidden_field :sim_id, id: "selected_sim" %>
        <div class="border rounded-lg p-2 text-sm text-gray-500">
          SIM seleccionada
        </div>
      </div>

    </div>

    <%= f.submit "Conectar",
        class: "bg-sky-600 hover:bg-sky-700 text-white px-6 py-2 rounded-xl font-semibold" %>

  <% end %>

</div>