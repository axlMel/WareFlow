<%= turbo_frame_tag "modal" do %>
  <div class="p-6" data-controller="modal">
    <%= render "shared/modal" do %>
      <div class="space-y-6">
        <h1 class="text-2xl font-bold text-gray-800 border-b mb-4">Detalles del dispositivo-
          <span class="inline-block px-1 py-1 font-semibold text-xl text-sky-600">ID: <%= @device.id %></span>
        </h1>

        <div class="bg-white rounded-2xl shadow-lg p-6 ring-1 ring-gray-200 space-y-6 text-sm text-gray-700">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div>
              <p class="text-base text-gray-500">Marca:</p>
              <p class="text-sm font-medium text-gray-900"><%= @device.brand || "-" %></p>
            </div>
            <div>
              <p class="text-base text-gray-500">Modelo:</p>
              <p class="text-sm font-medium text-gray-900"><%= @device.model || "Sin modelo" %></p>
            </div>
            <div>
              <p class="text-base text-gray-500">Estado:</p>
              <p class="text-sm font-medium text-gray-900"><%= @device.status.presence || "No status" %></p>
            </div>
            <div class="md:col-span-2">
              <p class="ftext-base text-gray-500">Fecha de creación:</p>
              <p class="text-sm font-medium text-gray-900"><%= l(@device.created_at, format: :long) %></p>
            </div>
          </div>

          <!-- Productos asignados -->
          <div>
            <h2 class="text-lg font-semibold text-gray-800 mb-2">Detalles del producto: </h2>

            <% if @device.product.present? %>
              <ul class="space-y-2 text-sm text-gray-700 list-disc pl-6">
                <li>
                  <span class="font-medium"><%= @device.product.title %></span>
                  – Cantidad: <%= @device.product.real_stock %>
                </li>

              </ul>
            <% end %>

            <h2 class="text-lg font-semibold text-gray-800 mb-2">Sim actual: </h2>

            <% if @device.active_sim %>
              <%= @device.active_sim.iccid %>
            <% else %>
              <span class="text-gray-400">Sin SIM</span>
            <% end %>
          </div>
        </div>
        <!-- Acciones -->
        <div class="flex justify-between items-center text-sm">
          <%= link_to "← Volver al listado", devices_path, class: "text-sky-600 hover:text-blue-800 font-medium transition" %>
          <% unless @device.installed? %>
            <%= link_to "Editar", edit_device_path(@device), data: { turbo_frame: "modal" }, class: "text-yellow-600 hover:text-yellow-700 font-medium transition" %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
<% end %>

