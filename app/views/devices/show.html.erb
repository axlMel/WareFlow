<div class="space-y-6">

  <!-- INFO DEVICE -->
  <div class="bg-white p-6 rounded-2xl shadow space-y-4">

    <h1 class="text-2xl font-bold text-gray-800">
      Dispositivo <span class="text-sky-600">#<%= @device.id %></span>
    </h1>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-gray-700 text-sm">

      <p><strong>Marca:</strong> <%= @device.brand || "-" %></p>

      <p><strong>Modelo:</strong> <%= @device.model || "-" %></p>

      <p><strong>Estado:</strong> <%= @device.status %></p>

      <p><strong>Fecha creación:</strong>
        <%= l(@device.created_at, format: :long) %>
      </p>

    </div>

  </div>


  <!-- SIM ACTUAL -->
  <div class="bg-white p-6 rounded-2xl shadow space-y-4">

    <h2 class="text-xl font-semibold text-gray-800">
      SIM actual
    </h2>

    <% if @device.active_sim %>

      <div class="flex justify-between items-center">

        <span class="text-lg font-mono text-blue-600">
          <%= @device.active_sim.iccid %>
        </span>

        <span class="text-sm text-gray-500">
          instalada <%= time_ago_in_words(@device.device_sim_histories.last.installed_at) %> ago
        </span>

      </div>

    <% else %>

      <span class="text-gray-400">
        Este dispositivo no tiene SIM instalada
      </span>

    <% end %>

  </div>


  <!-- SWAP SIM -->
  <div class="bg-white p-6 rounded-2xl shadow space-y-4">

    <h2 class="text-xl font-semibold text-gray-800">
      Reemplazar SIM
    </h2>

    <%= form_with url: swap_sim_device_path(@device), method: :post do %>

      <div class="flex gap-4 items-center">

        <select name="sim_id"
        class="border rounded-lg px-3 py-2 text-sm">

          <% @available_sims.each do |sim| %>

            <option value="<%= sim.id %>">
              <%= sim.iccid %>
            </option>

          <% end %>

        </select>

        <%= submit_tag "Reemplazar",
        class: "bg-orange-500 text-white px-4 py-2 rounded-lg hover:bg-orange-600" %>

      </div>

    <% end %>

  </div>


  <!-- HISTORIAL -->
  <div class="bg-white p-6 rounded-2xl shadow space-y-4">

    <h2 class="text-xl font-semibold text-gray-800">
      Historial de SIM
    </h2>

    <div class="overflow-x-auto rounded shadow">

      <table class="min-w-full text-sm border border-gray-200">

        <thead class="bg-gray-100 text-gray-700">

          <tr>

            <th class="px-4 py-2 border-b">SIM</th>
            <th class="px-4 py-2 border-b">Instalada</th>
            <th class="px-4 py-2 border-b">Removida</th>

          </tr>

        </thead>

        <tbody>

          <% @sim_history.each do |relation| %>

            <tr class="hover:bg-gray-50">

              <td class="px-4 py-2 border-b font-mono">
                <%= relation.sim.iccid %>
              </td>

              <td class="px-4 py-2 border-b">
                <%= relation.installed_at.strftime("%d/%m/%Y") %>
              </td>

              <td class="px-4 py-2 border-b">

                <% if relation.removed_at %>
                  <%= relation.removed_at.strftime("%d/%m/%Y") %>
                <% else %>
                  <span class="text-green-600 font-semibold">
                    Activa
                  </span>
                <% end %>

              </td>

            </tr>

          <% end %>

        </tbody>

      </table>

    </div>

  </div>


  <!-- ACCIONES -->

  <div class="flex justify-end gap-4">

    <%= link_to "Editar",
      edit_device_path(@device),
      class: "bg-yellow-500 text-white px-4 py-2 rounded-xl hover:bg-yellow-600" %>

    <%= link_to "Volver",
      devices_path,
      class: "bg-gray-300 text-gray-800 px-4 py-2 rounded-xl hover:bg-gray-400" %>

  </div>

</div>