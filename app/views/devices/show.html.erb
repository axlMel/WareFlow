<div class="space-y-6">
  <div class="grid grid-cols-1 xl:grid-cols-2 gap-6">
    <!-- INFO DEVICE -->
    <div class="bg-white p-6 rounded-2xl shadow space-y-4">
      <h1 class="text-2xl font-bold text-gray-800">
        Dispositivo <span class="text-sky-600">#<%= @device.id %></span>
      </h1>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-gray-700 text-sm border border-gray-200 rounded-xl p-4 ">
        <p><strong>IMEI:</strong> <%= @device.imei || "-" %></p>
        <p><strong>Marca:</strong> <%= @device.brand || "-" %></p>
        <p><strong>Modelo:</strong> <%= @device.model || "-" %></p>
        <p><strong>Estado:</strong> <span class="inline-flex px-2 py-1 rounded-full text-xs font-semibold <%= case @device.status 
                        when "available"
                          'bg-amber-100 text-amber-600'
                        when "assigned"
                          'bg-sky-100 text-sky-800'
                        when "installed"
                          'bg-green-100 text-green-800'
                        when "in_warranty"
                          'bg-orange-100 text-orange-600'
                        when "damaged"
                          'bg-rose-100 text-rose-800'
                        when "returned"
                          'bg-purple-100 text-purple-800'
                        end  %>">
                        <%= t("activerecord.attributes.device.statuses.#{@device.status}") %>
                      </span></p>
        <p><strong>Fecha creación:</strong> <%= l(@device.created_at, format: :long) %> </p>
        <p><strong>Asignación actual:</strong>
          <% if @active_sim.present? %>
            hace <%= time_ago_in_words(@active_history.installed_at) %>
          <% else %>
            -
          <% end %>
        </p>
        <p><strong>SIM:</strong> <%= @active_sim&.iccid || "Sin SIM asignada" %></p>
        <p><strong>Proveedor:</strong> <%= @active_sim&.provider || "-" %></p>
        <p><strong>APN:</strong> <%= @active_sim&.apn || "-" %></p>
        <p><strong>Numero telefónico:</strong> <%= @active_sim&.phone_number || "-" %></p>
      </div>
    </div>

    <div class="bg-white p-6 rounded-2xl shadow space-y-4"
     data-controller="device-movement"
     data-has-sim="<%= @active_sim.present? %>">

      <div class="flex flex-wrap gap-2">
        <% if @active_sim.present? %>
          <button type="button"
                  data-action="click->device-movement#setReplace"
                  class="px-3 py-2 rounded-lg bg-indigo-100 text-indigo-700 text-sm font-medium hover:bg-indigo-200">
            Reemplazar SIM
          </button>

          <button type="button"
                  data-action="click->device-movement#setRemove"
                  class="px-3 py-2 rounded-lg bg-gray-100 text-gray-700 text-sm font-medium hover:bg-gray-200">
            Quitar SIM
          </button>
        <% else %>
          <button type="button"
                  data-action="click->device-movement#setAssign"
                  class="px-3 py-2 rounded-lg bg-blue-100 text-blue-700 text-sm font-medium hover:bg-blue-200">
            Asignar SIM
          </button>
        <% end %>

        <button type="button"
                data-action="click->device-movement#setWarranty"
                class="px-3 py-2 rounded-lg bg-amber-100 text-amber-800 text-sm font-medium hover:bg-amber-200">
          Garantía
        </button>

        <button type="button"
                data-action="click->device-movement#setDamaged"
                class="px-3 py-2 rounded-lg bg-rose-100 text-rose-700 text-sm font-medium hover:bg-rose-200">
          Dañado
        </button>

        <button type="button"
                data-action="click->device-movement#setReturned"
                class="px-3 py-2 rounded-lg bg-purple-100 text-purple-700 text-sm font-medium hover:bg-purple-200">
          Devolución
        </button>
      </div>

      <div class="border border-gray-200 rounded-xl p-4 space-y-4">
        <div>
          <h3 data-device-movement-target="title"
              class="text-sm font-semibold text-gray-800">
          </h3>

          <p data-device-movement-target="description"
             class="text-xs text-gray-500 mt-1">
          </p>
        </div>

        <%= form_with url: swap_sim_device_path(@device), method: :post, class: "space-y-4" do %>
          <%= hidden_field_tag :action_type, nil, data: { device_movement_target: "actionType" } %>

          <div data-device-movement-target="simField">
            <label class="block text-sm font-medium text-gray-700 mb-1">SIM</label>
            <select name="sim_id" class="w-full border rounded-lg px-3 py-2 text-sm">
              <option value="">Selecciona una SIM</option>
              <% @available_sims.each do |sim| %>
                <option value="<%= sim.id %>">
                  <%= sim.iccid %> - <%= sim.provider %>
                </option>
              <% end %>
            </select>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Motivo</label>
            <textarea name="reason"
                      rows="3"
                      placeholder="Describe el motivo del movimiento..."
                      class="w-full border rounded-lg px-3 py-2 text-sm resize-none"></textarea>
          </div>

          <div class="flex justify-end">
            <%= submit_tag "Guardar movimiento",
              data: { device_movement_target: "submit" },
              class: "bg-slate-800 text-white px-4 py-2 rounded-xl hover:bg-slate-900 transition" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <!-- HISTORIAL -->
  <div class="bg-white p-6 rounded-2xl shadow space-y-4">
    <h2 class="text-xl font-semibold text-gray-800">
      Historial de relación con SIM
    </h2>
    <div class="overflow-x-auto rounded shadow">
      <% if @sim_history.empty? %>
        <div class="text-gray-400 text-sm">
          Aún no comienzas a relacionar este equipo
        </div>
      <% else %>
        <table class="min-w-full table-fixed text-xs border border-gray-200">
          <thead class="bg-gray-100 text-gray-700">
            <tr>
              <th class="px-4 py-2 border-b text-left">SIM</th>
              <th class="px-4 py-2 border-b text-left">Instalada</th>
              <th class="px-4 py-2 border-b text-left">Removida</th>
              <th class="px-4 py-2 border-b text-left">Motivo</th>
            </tr>
          </thead>
          <tbody>
            <% @sim_history.each_with_index do |relation, index| %>
              <tr class="
                border-b
                <%= relation.removed_at.nil? ? 'border-l-4 border-green-400' : '' %>
                <%= index.even? ? 'bg-white' : 'bg-gray-50' %>
                hover:bg-blue-50 transition">
                <!-- SIM -->
                <td class="px-3 py-2 font-mono truncate">
                  <%= relation.sim.iccid %>
                </td>
                <!-- Instalada -->
                <td class="px-3 py-2 truncate text-gray-600">
                  <%= relation.installed_at.strftime("%d/%m/%Y %H:%M") %>
                </td>
                <!-- Removida -->
                <td class="px-3 py-2 truncate">
                  <% if relation.removed_at %>
                    <span class="text-gray-500">
                      <%= relation.removed_at.strftime("%d/%m/%Y %H:%M") %>
                    </span>
                  <% else %>
                    <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[10px] font-semibold bg-green-100 text-green-700">
                      ● Activa
                    </span>
                  <% end %>
                </td>
                <!-- Motivo -->
                <td class="px-3 py-2 truncate text-gray-600" title="<%= relation.reasons %>">
                  <%= relation.reasons.presence || "-" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% end %>
    </div>
  </div>
  <!-- HISTORIAL DE MOVIMIENTOS -->
  <div class="bg-white p-6 rounded-2xl shadow space-y-4">
    <h2 class="text-xl font-semibold text-gray-800">
      Historial de movimientos
    </h2>

    <div class="overflow-x-auto rounded shadow">
      <% if @device.device_movements.empty? %>
        <div class="text-gray-400 text-sm">
          No hay movimientos registrados
        </div>
      <% else %>
        <table class="min-w-full table-fixed text-xs border border-gray-200">
          <thead class="bg-gray-100 text-gray-700">
            <tr>
              <th class="px-4 py-2 border-b text-left">Tipo</th>
              <th class="px-4 py-2 border-b text-left">Fecha</th>
              <th class="px-4 py-2 border-b text-left">Estado anterior</th>
              <th class="px-4 py-2 border-b text-left">SIM</th>
              <th class="px-4 py-2 border-b text-left">Motivo</th>
            </tr>
          </thead>

          <tbody>
            <% @movements.each do |movement| %>
              <tr class="hover:bg-teal-50">
                <td class="px-2 py-2 border-b truncate">
                  <span class="inline-block px-2 py-1 rounded-full text-[10px] font-semibold whitespace-nowrap <%= case movement.movement_type
                    when "created"
                      'bg-amber-100 text-amber-600'
                    when "sim_assigned"
                      'bg-cyan-100 text-cyan-800'
                    when "sim_replaced"
                      'bg-sky-100 text-sky-800'
                    when "sim_removed"
                      'bg-blue-100 text-blue-800'
                    when "installed_in_client"
                      'bg-green-100 text-green-800'
                    when "sent_to_warranty"
                      'bg-orange-100 text-orange-600'
                    when "marked_damaged"
                      'bg-rose-100 text-rose-800'
                    when "returned_to_provider"
                      'bg-purple-100 text-purple-800'
                  end %>">
                    <%= t("activerecord.attributes.movement.movement_type.#{movement.movement_type}") %>
                  </span>
                </td>

                <!-- Fecha -->
                <td class="px-4 py-2 border-b truncate text-[11px]">
                  <%= movement.performed_at.strftime("%d/%m/%Y %H:%M") %>
                </td>

                <!-- Estado anterior -->
                <td class="px-4 py-2 border-b truncate">
                  <% status_key = Device.statuses.key(movement.from_status) %>

                  <span class="inline-block px-2 py-1 rounded-full text-[10px] font-semibold whitespace-nowrap <%= case status_key
                    when "available"
                      'bg-amber-100 text-amber-600'
                    when "assigned"
                      'bg-sky-100 text-sky-800'
                    when "installed"
                      'bg-green-100 text-green-800'
                    when "in_warranty"
                      'bg-orange-100 text-orange-600'
                    when "damaged"
                      'bg-rose-100 text-rose-800'
                    when "returned"
                      'bg-purple-100 text-purple-800'
                    else
                      'bg-gray-100 text-gray-500'
                  end %>">
                    <%= status_key.present? ?
                        t("activerecord.attributes.device.statuses.#{status_key}")
                        : "-" %>
                  </span>
                </td>

                <!-- SIM -->
                <td class="px-4 py-2 border-b font-mono truncate">
                  <%= movement.sim&.iccid || "-" %>
                </td>

                <!-- Motivo -->
                <td class="px-4 py-2 border-b truncate" title="<%= movement.reason %>">
                  <%= movement.reason %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% end %>
    </div>
  </div>
  <!-- ACCIONES -->
  <div class="flex justify-end gap-4">
    <%= link_to "Editar", edit_device_path(@device), data: { turbo_frame: "modal" }, class: "bg-yellow-500 text-white px-4 py-2 rounded-xl hover:bg-yellow-600" %>

    <%= link_to "Volver",
      devices_path,
      class: "bg-gray-300 text-gray-800 px-4 py-2 rounded-xl hover:bg-gray-400" %>
  </div>
</div>